# Plane Tracker RGB Pi Configuration
# Copy this file to .env and fill in your values

# Tomorrow.io Weather API Key
# Get one at: https://tomorrow.io (free tier allows 25 requests/hour)
TOMORROW_API_KEY=your_api_key_here

# Email Alerts Configuration
# Leave EMAIL empty to disable email alerts
EMAIL=your_email@example.com

# Email sender credentials (Gmail App Password recommended)
# See: https://support.google.com/accounts/answer/185833
EMAIL_SENDER=your_sender@gmail.com
EMAIL_PASSWORD=your_app_password_here

# Location Configuration
HOME_LATITUDE=44.797734
HOME_LONGITUDE=-93.186722

# Zone boundaries for flight detection
ZONE_TL_LATITUDE=44.757601
ZONE_TL_LONGITUDE=-93.226722
ZONE_BR_LATITUDE=44.837734
ZONE_BR_LONGITUDE=-93.146722

# Display Settings
BRIGHTNESS=100
BRIGHTNESS_NIGHT=50
NIGHT_BRIGHTNESS_ENABLED=false
NIGHT_START=22:00
NIGHT_END=06:00

# Hardware Settings
GPIO_SLOWDOWN=4
HAT_PWM_ENABLED=false

# Flight Tracker Settings
MIN_ALTITUDE=2000
JOURNEY_CODE_SELECTED=MSP
JOURNEY_BLANK_FILLER=" ? "
MAX_CLOSEST=3
MAX_FARTHEST=3

# Units and Format
TEMPERATURE_UNITS=imperial
DISTANCE_UNITS=imperial
CLOCK_FORMAT=12hr
FORECAST_DAYS=3


ADSB_URL = "https://api.adsb.lol/v2/point/{lat}/{lon}/{range}"
# To use a local ADS-B receiver with tar0190, set ADSB_URL to something like:
# ADSB_URL = "http://192.168.10.120/tar1090/data/aircraft.json"

# Elasticsearch SWIM API URL
SWIM_API_URL = "https://swims-host:443"

# Elastic SWIM API Key
SWIM_API_KEY = "XYZ12345"  # Replace with your actual API key

RANGE=10